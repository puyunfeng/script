-- ================= 配置区域 =================
local CONFIG = {
  targetSSID = "Redmi K60 Ultra",
  defaultProxyPort = "2080",
  -- 🔧 新增：代理地址策略
  -- "loopback" = 始终用 127.0.0.1（推荐，兼容 Clash/Surge 等）
  -- "gateway"  = 目标 WiFi 时用网关地址，其他用 127.0.0.1
  proxyAddressMode = "gateway",
  scriptPath = nil
}

-- 🔧 创建 logger 实例
local log = hs.logger.new('WiFiProxy', 'info')

-- ================= 辅助函数：获取网关 IP =================
-- ================= 增强版日志：获取网关 IP =================
local function getGatewayIP()
  log:i("🔍 开始探测网关 IP...")
  local ip = nil

  for i = 1, 3 do
    log:d(string.format("尝试第 %d 次抓取...", i))
    
    -- 【方案 A】解析 netstat - 最底层，不依赖服务名
    local handle = io.popen("netstat -rn | grep 'default' | awk '{print $2}' | head -n 1")
    local result = handle:read("*all"):gsub("%s+", "")
    handle:close()

    if result and result:match("^%d+%.%d+%.%d+%.%d+$") and result ~= "127.0.0.1" then
      ip = result
      log:i("🎯 探测成功 (netstat): " .. ip)
      break
    end

    -- 【方案 B】networksetup 兜底
    handle = io.popen("networksetup -getinfo 'Wi-Fi' | grep 'Router:' | awk '{print $2}'")
    result = handle:read("*all"):gsub("%s+", "")
    handle:close()
    
    if result and result:match("^%d+%.%d+%.%d+%.%d+$") then
      ip = result
      log:i("🎯 探测成功 (networksetup): " .. ip)
      break
    end

    if i < 3 then hs.timer.usleep(1000000) end -- 失败则等待 1 秒再重试
  end

  if not ip then
    log:e("❌ 无法获取网关，回退到 127.0.0.1")
    return "127.0.0.1"
  end
  return ip
end

-- ================= 辅助函数：获取代理地址（核心逻辑） =================
local function getProxyAddress()
  -- 🔧 根据配置策略决定代理地址
  if CONFIG.proxyAddressMode == "gateway" then
    -- 仅当连接到目标 WiFi 时，才尝试获取网关地址
    local current = hs.wifi.currentNetwork()
    if current == CONFIG.targetSSID then
      return getGatewayIP()
    end
  end
  -- 默认返回本机回环地址（兼容绝大多数代理软件）
  return "127.0.0.1"
end

-- ================= 辅助函数：设置 Terminal 代理 =================
local function setShellProxy(enable, ip, port)
  local zshrcPath = os.getenv("HOME") .. "/.zshrc"
  
  -- 1. 读取所有行
  local lines = {}
  local file = io.open(zshrcPath, "r")
  if file then
    for line in file:lines() do
      -- 核心逻辑：排除掉任何包含代理关键字或残留横线的行
      -- 这里包含了你之前出现的各种“变异”版本
      local shouldSkip = line:find("http_proxy") or 
                         line:find("https_proxy") or 
                         line:find("all_proxy") or 
                         line:find("no_proxy") or 
                         line:find("%-%-%-") or -- 转义匹配 ---
                         line:find("Hammerspoon Proxy")
      
      if not shouldSkip then
        table.insert(lines, line)
      end
    end
    file:close()
  end

  -- 2. 清理末尾多余空行
  while #lines > 0 and lines[#lines]:gsub("%s+", "") == "" do
    table.remove(lines)
  end

  -- 3. 如果是启用状态，追加新配置
  if enable then
    local marker = "### --- Hammerspoon Proxy --- ###"
    table.insert(lines, "\n" .. marker)
    table.insert(lines, string.format('export http_proxy="http://%s:%s"', ip, port))
    table.insert(lines, string.format('export https_proxy="http://%s:%s"', ip, port))
    table.insert(lines, string.format('export all_proxy="socks5://%s:%s"', ip, port))
    table.insert(lines, 'export no_proxy="localhost,127.0.0.1,local,.local"')
    table.insert(lines, marker)
    
    hs.notify.new({title="Terminal 代理", informativeText="✅ 已写入新配置: " .. ip}):send()
  else
    hs.notify.new({title="Terminal 代理", informativeText="❌ 已彻底清理残留"}):send()
  end

  -- 4. 写回文件
  file = io.open(zshrcPath, "w")
  if file then
    file:write(table.concat(lines, "\n") .. "\n")
    file:close()
  end
end

-- ================= 代理设置主函数 =================
local function setProxy(enable)
  local service = "Wi-Fi"
  local port = CONFIG.defaultProxyPort
  
  -- 🔧 核心：仅在启用代理时获取地址
  local ip = enable and getProxyAddress() or "127.0.0.1"
  
  log:i(string.format("🔄 代理 %s | %s:%s", 
    enable and "ON" or "OFF", ip, port))

  if enable then
    -- 设置系统代理
    local cmd = string.format(
      "networksetup -setwebproxy '%s' %s %s && " ..
      "networksetup -setwebproxystate '%s' on && " ..
      "networksetup -setsecurewebproxy '%s' %s %s && " ..
      "networksetup -setsecurewebproxystate '%s' on && " ..
      "networksetup -setsocksfirewallproxy '%s' %s %s && " ..
      "networksetup -setsocksfirewallproxystate '%s' on",
      service, ip, port, service, service, ip, port, service, service, ip, port, service
    )
    hs.execute(cmd)
    
    -- 设置 Terminal 代理
    setShellProxy(true, ip, port)
    
    hs.notify.new({
      title="🎯 WiFi 代理 ("..CONFIG.targetSSID..")", 
      informativeText=string.format("✅ 代理已启用\n📍 %s:%s", ip, port)
    }):send()
  else
    -- 关闭系统代理
    hs.execute(string.format(
      "networksetup -setwebproxystate '%s' off && " ..
      "networksetup -setsecurewebproxystate '%s' off && " ..
      "networksetup -setsocksfirewallproxystate '%s' off",
      service, service, service
    ))
    
    -- 关闭 Terminal 代理
    setShellProxy(false, ip, port)
    
    hs.notify.new({title="WiFi 代理", informativeText="❌ 代理已关闭"}):send()
  end
end

-- ================= WiFi 监听核心逻辑 =================
local lastSSID = nil

local function wifiChanged()
  local currentSSID = hs.wifi.currentNetwork()
  if currentSSID == lastSSID then return end
  
  log:i(string.format("📡 WiFi: %s → %s", lastSSID or "【无】", currentSSID or "【无】"))
  
  if lastSSID == CONFIG.targetSSID then
    setProxy(false)
  end
  
  if currentSSID == CONFIG.targetSSID then
    -- 🕒 关键：延迟 2 秒执行，等 DHCP 分配 IP 完成
    hs.timer.doAfter(2, function()
      setProxy(true)
    end)
  end
  
  lastSSID = currentSSID
end

-- ================= 启动监听 =================
local wifiWatcher = hs.wifi.watcher.new(wifiChanged)
wifiWatcher:start()
log:i("✅ WiFiProxy 监控已启动，目标: " .. CONFIG.targetSSID)

-- 启动时立即检查当前状态
hs.timer.doAfter(1, function()
  local current = hs.wifi.currentNetwork()
  log:i("✅ 启动时检测到 WiFi: " .. current)
  if current == CONFIG.targetSSID then
    log:i("🎯 启动时已连接目标 WiFi，自动启用代理")
    setProxy(true)
  end
  lastSSID = current
end)